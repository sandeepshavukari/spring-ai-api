# ─── MySQL ───────────────────────────────────────────────
MYSQL_URL=jdbc:mysql://localhost:3306/springai_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password

# ─── File Storage ─────────────────────────────────────────
UPLOAD_DIR=uploads

# ─── xAI Grok ────────────────────────────────────────────
# Get your API key from https://console.x.ai
GROK_API_KEY=xai-your-key-here
GROK_MODEL=grok-3-mini

# ─── JWT ─────────────────────────────────────────────────
# Generate a strong 256-bit hex secret
JWT_SECRET=your-256-bit-hex-secret
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── OAuth2 (Google) ─────────────────────────────────────
# Create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH2_REDIRECT_URI=http://localhost:4200/oauth2/callback

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200

# ─── Rate Limits ─────────────────────────────────────────
RATE_LIMIT_USER=50
RATE_LIMIT_PREMIUM=1000
